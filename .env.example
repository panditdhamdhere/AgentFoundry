# Pinata (IPFS) - required for agent card and image uploads
# Get keys at https://pinata.cloud/
PINATA_JWT=
PINATA_GATEWAY=

# WalletConnect - required for wallet connection
# Get project ID at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Optional: API key for /api/v1/* endpoints (agent-card, upload).
# If set, programmatic requests must include: x-api-key: <your-key>
# Leave empty to allow public access. UI uses /api/upload (unaffected).
# API_KEY=

# Optional: RPC URLs for reputation API (falls back to public RPC if unset)
# Use Alchemy, Infura, or QuickNode for reliable production RPC
# NODE_RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# NODE_RPC_URL_BASE_SEPOLIA=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Optional: Upstash Redis for rate limiting (recommended for multi-instance/Vercel)
# Without these, rate limiting uses in-memory store (per-instance).
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# Optional: Sentry error monitoring (sentry.io)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=  (for source map uploads)
