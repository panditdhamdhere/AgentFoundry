# Pinata (IPFS) - required for agent card and image uploads
# Get keys at https://pinata.cloud/
PINATA_JWT=
PINATA_GATEWAY=

# WalletConnect - required for wallet connection
# Get project ID at https://cloud.walletconnect.com/
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Beta gating: Registration is invite-only by default.
# Set BETA_PUBLIC_REGISTRATION=true to open registration to everyone.
# BETA_PUBLIC_REGISTRATION=true

# When gated, set BETA_ACCESS_CODE to share with invitees. They enter it to access /register.
# BETA_ACCESS_CODE=your-secret-code

# Optional: API key for /api/v1/* endpoints (agent-card, upload).
# If set, programmatic requests must include: x-api-key: <your-key>
# Leave empty to allow public access. UI uses /api/upload (unaffected).
# API_KEY=

# Optional: Subgraph URL for directory (replaces raw RPC event scanning when set)
# Per-chain: SUBGRAPH_URL_<chainId>=https://api.studio.thegraph.com/query/.../erc8004/version/latest
# SUBGRAPH_URL=https://api.studio.thegraph.com/query/.../erc8004-base-sepolia/version/latest

# Optional: RPC URLs for reputation API (falls back to public RPC if unset)
# Use Alchemy, Infura, or QuickNode for reliable production RPC
# NODE_RPC_URL_MAINNET=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
# NODE_RPC_URL_BASE_SEPOLIA=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# Optional per-chain override format for any supported chain:
# NODE_RPC_URL_<CHAIN_ID>=https://...
# Example: NODE_RPC_URL_8453=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Optional: Upstash Redis for rate limiting + metadata cache (recommended for multi-instance/Vercel)
# Without these, rate limiting uses in-memory store; metadata is not cached.
# UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxx

# Optional: SIWE (Sign-In with Ethereum) - required for persistent wallet sessions
# Generate with: openssl rand -base64 32
# SIWE_SECRET=your-secret

# Optional: Sentry error monitoring (sentry.io)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG=your-org
# SENTRY_PROJECT=your-project
# SENTRY_AUTH_TOKEN=  (for source map uploads)
