{
  "name": "@panditdhamdhere/agentfoundry-sdk",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/panditdhamdhere/AgentFoundry.git",
    "directory": "packages/sdk"
  },
  "version": "0.1.0",
  "description": "Official SDK for AgentFoundry - ERC-8004 agent registration and discovery",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch"
  },
  "keywords": ["agentfoundry", "erc-8004", "ethereum", "agents", "sdk"],
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5"
  }
}
